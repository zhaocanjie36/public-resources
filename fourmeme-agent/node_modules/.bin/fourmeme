#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/root/.openclaw/workspace/fourmeme-agent/node_modules/.pnpm/@four-meme+four-meme-ai@1.0.4/node_modules/@four-meme/four-meme-ai/node_modules:/root/.openclaw/workspace/fourmeme-agent/node_modules/.pnpm/@four-meme+four-meme-ai@1.0.4/node_modules:/root/.openclaw/workspace/fourmeme-agent/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/root/.openclaw/workspace/fourmeme-agent/node_modules/.pnpm/@four-meme+four-meme-ai@1.0.4/node_modules/@four-meme/four-meme-ai/node_modules:/root/.openclaw/workspace/fourmeme-agent/node_modules/.pnpm/@four-meme+four-meme-ai@1.0.4/node_modules:/root/.openclaw/workspace/fourmeme-agent/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../.pnpm/@four-meme+four-meme-ai@1.0.4/node_modules/@four-meme/four-meme-ai/bin/fourmeme.cjs" "$@"
else
  exec node  "$basedir/../.pnpm/@four-meme+four-meme-ai@1.0.4/node_modules/@four-meme/four-meme-ai/bin/fourmeme.cjs" "$@"
fi
